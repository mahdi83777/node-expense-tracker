<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Expense</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">

  <h1 class="mb-4">Edit Expense</h1>

  <form action="/edit/<%= expense._id %>" method="POST">
    <div class="mb-3">
      <input type="text" name="item" class="form-control" value="<%= expense.item %>" required>
    </div>
    <div class="mb-3">
      <input type="text" name="category" class="form-control" value="<%= expense.category %>" required>
    </div>
    <div class="mb-3">
      <input type="number" name="amount" class="form-control" value="<%= expense.amount %>" required step="0.01">
    </div>
    <button class="btn btn-success" type="submit">Update</button>
    <a href="/" class="btn btn-secondary">Cancel</a>
  </form>

</body>
</html>