<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Expense Tracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">

  <h1 class="mb-4">Expense Tracker</h1>

  <form action="/add-expense" method="POST" class="mb-4">
    <div class="row g-2">
      <div class="col">
        <input type="text" name="item" class="form-control" placeholder="Item" required>
      </div>
      <div class="col">
        <input type="text" name="category" class="form-control" placeholder="Category" required>
      </div>
      <div class="col">
        <input type="number" name="amount" class="form-control" placeholder="Amount" required step="0.01">
      </div>
      <div class="col-auto">
        <button class="btn btn-primary" type="submit">Add Expense</button>
      </div>
    </div>
  </form>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Item</th>
        <th>Category</th>
        <th>Amount</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% expenses.forEach(expense => { %>
        <tr>
          <td><%= expense.item %></td>
          <td><%= expense.category %></td>
          <td>$<%= expense.amount.toFixed(2) %></td>
          <td>
            <a href="/edit/<%= expense._id %>" class="btn btn-sm btn-warning">Edit</a>
            <a href="/delete/<%= expense._id %>" class="btn btn-sm btn-danger">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</body>
</html>